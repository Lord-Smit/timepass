<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Captured Data Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0f0f0f; color: #e0e0e0; padding: 2rem;
    }
    h1 { margin-bottom: 0.5rem; color: #fff; }
    .stats {
      display: flex; gap: 1rem; margin: 1.5rem 0; flex-wrap: wrap;
    }
    .stat-card {
      background: #1a1a2e; padding: 1.5rem; border-radius: 12px; flex: 1; min-width: 140px;
    }
    .stat-card h3 { font-size: 2rem; color: #e94560; }
    .stat-card p { color: #aaa; font-size: 0.85rem; }
    table {
      width: 100%; border-collapse: collapse; background: #1a1a2e;
      border-radius: 12px; overflow: hidden; margin-top: 1rem;
    }
    th { background: #16213e; color: #e94560; padding: 1rem; text-align: left; font-size: 0.85rem; }
    td { padding: 0.85rem 1rem; border-bottom: 1px solid #16213e; font-size: 0.85rem; }
    tr:hover { background: #16213e; }
    .badge {
      display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem;
    }
    .badge-desktop { background: #0f3460; color: #4fc3f7; }
    .badge-mobile { background: #1b5e20; color: #81c784; }
    .badge-tablet { background: #e65100; color: #ffcc80; }
    .empty {
      text-align: center; padding: 3rem; color: #666;
    }
    .toolbar { margin: 1rem 0; display: flex; gap: 1rem; align-items: center; }
    input, button {
      padding: 0.6rem 1rem; border: none; border-radius: 8px; font-size: 0.85rem;
    }
    input { background: #1a1a2e; color: #fff; flex: 1; max-width: 400px; border: 1px solid #16213e; }
    button { background: #e94560; color: #fff; cursor: pointer; }
    button:hover { background: #d63851; }
    .result { margin-top: 0.5rem; color: #81c784; font-size: 0.85rem; }
  </style>
</head>
<body>
  <h1>Captured Data Dashboard</h1>
  <p style="color:#aaa;">Information gathered from visitors who accessed the tracking page.</p>

  <div class="stats">
    <div class="stat-card">
      <h3><%= count %></h3>
      <p>Total Captures</p>
    </div>
    <div class="stat-card">
      <h3><%= [...new Set(captures.map(c => c.ip))].length %></h3>
      <p>Unique IPs</p>
    </div>
    <div class="stat-card">
      <h3><%= [...new Set(captures.map(c => c.os))].length %></h3>
      <p>Unique OS</p>
    </div>
  </div>

  <div class="toolbar">
    <input type="url" id="urlInput" placeholder="Enter a URL to shorten with Bitly..." />
    <button onclick="shortenURL()">Shorten with Bitly</button>
  </div>
  <div id="result" class="result"></div>

  <% if (captures.length === 0) { %>
    <div class="empty">No captures yet. Share your Bitly link and wait for visits.</div>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Timestamp</th>
          <th>IP Address</th>
          <th>OS</th>
          <th>Browser</th>
          <th>Device</th>
          <th>Referer</th>
        </tr>
      </thead>
      <tbody>
        <% captures.slice().reverse().forEach(c => { %>
          <tr>
            <td><%= new Date(c.timestamp).toLocaleString() %></td>
            <td><%= c.ip %></td>
            <td><%= c.os %></td>
            <td><%= c.browser %></td>
            <td><span class="badge badge-<%= c.device %>"><%= c.device %></span></td>
            <td><%= c.referer %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>

  <script>
    async function shortenURL() {
      const url = document.getElementById('urlInput').value;
      const resultDiv = document.getElementById('result');
      if (!url) { resultDiv.textContent = 'Please enter a URL.'; return; }

      try {
        const res = await fetch('/api/shorten', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url })
        });
        const data = await res.json();
        if (data.link) {
          resultDiv.innerHTML = `Shortened URL: <a href="${data.link}" target="_blank">${data.link}</a>`;
        } else {
          resultDiv.textContent = 'Error: ' + (data.error || 'Unknown error');
        }
      } catch (err) {
        resultDiv.textContent = 'Error: ' + err.message;
      }
    }
  </script>
</body>
</html>
