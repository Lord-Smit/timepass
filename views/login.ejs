<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Login</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0a0a0f; color: #e0e0e0; height: 100vh;
      display: flex; align-items: center; justify-content: center;
    }
    .login-card {
      background: #12121a; border: 1px solid #1e1e2e; border-radius: 16px;
      padding: 2.5rem; width: 100%; max-width: 380px; text-align: center;
    }
    .login-card .logo { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.3rem; }
    .login-card .logo span { color: #e94560; }
    .login-card .sub { color: #666; font-size: 0.85rem; margin-bottom: 2rem; }
    .login-card label {
      display: block; text-align: left; font-size: 0.75rem; font-weight: 600;
      color: #aaa; margin-bottom: 0.3rem; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .login-card input {
      width: 100%; padding: 0.7rem 0.9rem; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; color: #fff;
      font-size: 0.9rem; margin-bottom: 1.2rem; transition: 0.2s;
    }
    .login-card input:focus { outline: none; border-color: #e94560; box-shadow: 0 0 0 3px rgba(233,69,96,0.15); }
    .login-card button {
      width: 100%; padding: 0.75rem; background: #e94560; color: #fff;
      border: none; border-radius: 8px; font-size: 0.9rem; font-weight: 600; cursor: pointer;
    }
    .login-card button:hover { background: #d63851; }
    .error { color: #e94560; font-size: 0.8rem; margin-bottom: 1rem; }
    .hint { color: #444; font-size: 0.7rem; margin-top: 1.5rem; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo"><span>Hisernberg Sim</span></div>
    <p class="sub">Authenticate to access the dashboard</p>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <form method="POST" action="/login">
      <label>Username</label>
      <input type="text" name="username" placeholder="Enter username" required autocomplete="off">
      <label>Password</label>
      <input type="password" name="password" placeholder="Enter password" required>
      <button type="submit">Sign In</button>
    </form>
    <div class="hint">Authorized access only</div>
  </div>
</body>
</html>

