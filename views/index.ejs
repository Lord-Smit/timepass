<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redirecting...</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      height: 100vh; display: flex; align-items: center; justify-content: center;
      background: #0f0f0f; color: #e0e0e0;
    }
    .card {
      background: #1a1a2e; padding: 3rem; border-radius: 16px;
      text-align: center; max-width: 480px; box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    }
    .spinner {
      width: 48px; height: 48px; border: 4px solid #16213e;
      border-top: 4px solid #e94560; border-radius: 50%;
      animation: spin 1s linear infinite; margin: 0 auto 1.5rem;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    h1 { font-size: 1.5rem; margin-bottom: 0.5rem; color: #fff; }
    p { color: #aaa; font-size: 0.9rem; }
    .info { margin-top: 2rem; padding: 1rem; background: #0f3460; border-radius: 8px; font-size: 0.8rem; }
    .info span { color: #e94560; }
  </style>
</head>
<body>
  <div class="card">
    <div class="spinner"></div>
    <h1>Please wait, redirecting...</h1>
    <p>You are being redirected to the requested page.</p>
    <div class="info">
      This is a demonstration page for educational purposes.<br>
      Your information has been logged: <span><%= capture.ip %></span>
    </div>
  </div>
  <script>
    setTimeout(() => {
      window.location.href = 'https://www.youtube.com/watch?v=_Ey3kJXtPoo';
    }, 3000);
  </script>
</body>
</html>
